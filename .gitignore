# Hidden entries at the repo root (dotfiles/dotdirs): ignore by default,
# then allow the ones we actually want to track.
/.[!.]*
/.?*
!/.gitignore
!/.golangci.yml
!/.github

# Go build / test artifacts
*.exe
*.test
*.out
*.prof
coverage.*
/bin/
/dist/

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
